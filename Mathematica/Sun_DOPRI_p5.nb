Cell[CellGroupData[{

Cell["The `funcLastQPeriod` function", "Subsection",
 CellChangeTimes->{{3.971381581101433*^9, 3.9713818180972843`*^9}, {
  3.9713931110421066`*^9, 
  3.971393118409851*^9}},ExpressionUUID->"c44ec035-fb3a-4446-84be-\
0504e1d045a8"],

Cell["\<\
Takes two arguments: function handler and integer.

This is very specific function. The real and imaginary parts of the solution \
\[OpenCurlyDoubleQuote]oscillates\[CloseCurlyDoubleQuote] very often, but the \
first component (which is true for the Sun model) at the right edge of the \
interval (\\(\\xi=1\\)) stops oscillating and \
\[OpenCurlyDoubleQuote]asymptotically\[CloseCurlyDoubleQuote] tends to a \
value (zero).\[LineSeparator]\[LineSeparator]This function finds the last \
three zeroes, such that after the last one there no more zeroes.\
\[LineSeparator]\[LineSeparator]Returns array of zero ranges.

Designed only for real and imaginary parts of first component.\
\>", "Text",
 CellChangeTimes->{{3.9713931053553143`*^9, 3.9713932271905384`*^9}, {
  3.9713932953286533`*^9, 
  3.9713932982314777`*^9}},ExpressionUUID->"ed1fc944-6047-0b4f-85be-\
cee2acbbd2c8"],

Cell[BoxData[
 RowBox[{
  RowBox[{"xi0", "=", "0.5"}], ";", 
  RowBox[{"xi1", "=", "0.99"}], ";"}]], "Input",
 CellChangeTimes->{{3.9719971414723473`*^9, 
  3.9719971487333965`*^9}},ExpressionUUID->"b27a454a-9a04-c341-816d-\
9246c3b54b53"],

Cell[BoxData[
 RowBox[{
  RowBox[{"funcLastQPeriod", "[", 
   RowBox[{"fn_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x0", "=", "xi0"}], ",", 
      RowBox[{"x2", "=", "xi1"}], ",", 
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"tt", "=", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{"y1", "=", "0"}], ",", 
      RowBox[{"y2", "=", "0"}], ",", 
      RowBox[{"y3", "=", "0"}], ",", 
      RowBox[{"eps", "=", 
       RowBox[{"10", "^", 
        RowBox[{"-", "8"}]}]}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"tt", "=", 
      RowBox[{"funcNullRangesStab", "[", 
       RowBox[{"fn", ",", "x0", ",", "x2", ",", "n"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"k", "=", 
      RowBox[{"Length", "[", "tt", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"y1", "=", 
      RowBox[{"funcTochnNull", "[", 
       RowBox[{"fn", ",", 
        RowBox[{"tt", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"k", "-", "2"}], ",", "1"}], "]"}], "]"}], ",", 
        RowBox[{"tt", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"k", "-", "2"}], ",", "2"}], "]"}], "]"}], ",", "eps"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"y2", "=", 
      RowBox[{"funcTochnNull", "[", 
       RowBox[{"fn", ",", 
        RowBox[{"tt", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"k", "-", "1"}], ",", "1"}], "]"}], "]"}], ",", 
        RowBox[{"tt", "[", 
         RowBox[{"[", 
          RowBox[{
           RowBox[{"k", "-", "1"}], ",", "2"}], "]"}], "]"}], ",", "eps"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"y3", "=", 
      RowBox[{"funcTochnNull", "[", 
       RowBox[{"fn", ",", 
        RowBox[{"tt", "[", 
         RowBox[{"[", 
          RowBox[{"k", ",", "1"}], "]"}], "]"}], ",", 
        RowBox[{"tt", "[", 
         RowBox[{"[", 
          RowBox[{"k", ",", "2"}], "]"}], "]"}], ",", "eps"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"List", "[", 
      RowBox[{"y1", ",", "y2", ",", "y3"}], "]"}]}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.9712947275976562`*^9, 3.9712948832261143`*^9}, {
   3.971294952112836*^9, 3.971295105062111*^9}, 3.971295349029467*^9, {
   3.9712955336075287`*^9, 3.9712955418157663`*^9}, {3.971295577191045*^9, 
   3.9712957390765867`*^9}, {3.971296239292989*^9, 3.97129627651645*^9}, {
   3.9712963275717382`*^9, 3.971296367622334*^9}, {3.971375184277954*^9, 
   3.9713752195363693`*^9}, {3.971376350479946*^9, 3.9713763648763638`*^9}, {
   3.971376429371359*^9, 3.971376429697859*^9}, {3.9713932474343433`*^9, 
   3.9713932606402454`*^9}, {3.9713998624608135`*^9, 
   3.9713998777087116`*^9}, {3.9714030610224667`*^9, 3.971403063733612*^9}, {
   3.9719971535022545`*^9, 
   3.9719971571989594`*^9}},ExpressionUUID->"a52ff5d8-e1d6-4ddf-80cd-\
1c6bd20463f0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["The `funcQPeriodStat` function", "Subsection",
 CellChangeTimes->{{3.971383060806761*^9, 3.9713831343091164`*^9}, {
  3.9713833367745495`*^9, 3.9713833695539665`*^9}, {3.971383715753851*^9, 
  3.971383994772335*^9}, {3.971384230540886*^9, 3.9713843208637657`*^9}, {
  3.9713844513369465`*^9, 3.971384452345333*^9}, {3.9713936486648293`*^9, 
  3.97139364948127*^9}},ExpressionUUID->"591bf29e-d69c-8849-997b-\
ede968b525dd"],

Cell["\<\
Takes three arguments: function handler and two integers. The first integer \
is a number of \[OpenCurlyDoubleQuote]rough tries\[CloseCurlyDoubleQuote], \
the second one is the number of random sample points.

Despite the name it works only with real and imaginary parts of first \
component (though technically, could work with second component too) and \
returns array of two element array. The first element is the random point \
within predefined interval, the second element is the width of zero range \
containing the random point.

The function handler and number of \[OpenCurlyDoubleQuote]rough tries\
\[CloseCurlyDoubleQuote] are passed to `funcLastQPeriod` function.

The random points are generated by `getSRandoms` function. The interval is \
predefined and doesn\[CloseCurlyQuote]t changed: \\((0,11;0,99)\\).

As we are interested in how the \[OpenCurlyDoubleQuote]quasiperiod\
\[CloseCurlyDoubleQuote] (the width of zero range) changes while goes from \
left to right by \\(\\xi\\), we collect the data in an array.

Later, it could be used by other routines to obtain data for second and third \
components.\
\>", "Text",
 CellChangeTimes->{
  3.971393643009634*^9, {3.9713938475221367`*^9, 
   3.9713942348824596`*^9}},ExpressionUUID->"e3ecf0c3-0816-4743-a618-\
ff7b0cabdfc6"],

Cell[BoxData[
 RowBox[{"xi0", "=", "0.11"}]], "Input",
 CellChangeTimes->{{3.971997196984827*^9, 
  3.9719971994024925`*^9}},ExpressionUUID->"fb75f42a-9bef-8b42-9034-\
e139058f3004"],

Cell[BoxData[
 RowBox[{
  RowBox[{"funcQPeriodStat", "[", 
   RowBox[{"fn_", ",", "nSeed_", ",", " ", "nSteps_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"tabQPeriod", "=", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{"endt", "=", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{"x00", "=", "0"}], ",", 
      RowBox[{"x01", "=", "0"}], ",", 
      RowBox[{"x02", "=", "0"}], ",", 
      RowBox[{"x0", "=", "xi0"}], ",", 
      RowBox[{"gran1", "=", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{"dx", "=", "0"}], ",", 
      RowBox[{"t", "=", "0"}], ",", 
      RowBox[{"pf", "=", 
       RowBox[{"{", 
        RowBox[{"1", ",", 
         RowBox[{"3", "/", "2"}], ",", 
         RowBox[{"7", "/", "4"}], ",", "2"}], "}"}]}], ",", 
      RowBox[{"k", "=", "1"}], ",", 
      RowBox[{"fl", "=", "1"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"endt", "=", 
      RowBox[{"funcLastQPeriod", "[", 
       RowBox[{"fn", ",", "nSeed"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"dx", "=", 
      RowBox[{
       RowBox[{"endt", "[", 
        RowBox[{"[", 
         RowBox[{"3", ",", "1"}], "]"}], "]"}], "-", 
       RowBox[{"endt", "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1"}], "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AppendTo", "[", 
      RowBox[{"tabQPeriod", ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"endt", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
         RowBox[{"endt", "[", 
          RowBox[{"[", 
           RowBox[{"3", ",", "1"}], "]"}], "]"}]}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"fl", "=", 
      RowBox[{"Length", "[", "pf", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"i", "<=", "nSteps"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"t", "=", 
         RowBox[{"tabQPeriod", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "1"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"x02", "=", 
         RowBox[{"t", "+", 
          RowBox[{"dx", "/", "4"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"Label", "[", "rechoose", "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"x01", "=", 
         RowBox[{"t", "-", 
          RowBox[{
           RowBox[{"pf", "[", 
            RowBox[{"[", "k", "]"}], "]"}], " ", "dx"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"x00", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x01", "+", "x02"}], ")"}], "/", "2"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"x01", "<", "x0"}], ",", 
          RowBox[{
           RowBox[{"Print", "[", 
            
            RowBox[{"\"\<[WARNING] reached the lower bound (\>\"", ",", " ", 
             "x0", ",", "\"\<) on step '\>\"", ",", " ", "i", 
             ",", "\"\<'\>\""}], "]"}], ";", " ", "tabQPeriod", ";", 
           RowBox[{"Break", "[", "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Print", "[", 
           
           RowBox[{"\"\<[DEBUG.funcQPeriodStat] i = \>\"", ",", " ", "i", ",",
             " ", "\"\<; (\>\"", ",", " ", "x01", ",", " ", "\"\<; \>\"", ",",
             "x02", ",", "\"\<); x00 = \>\"", ",", " ", "x00", ",", 
            " ", "\"\<; t = \>\"", ",", " ", "t", ",", " ", "\"\<; dx = \>\"",
             ",", " ", "dx"}], "]"}], ";"}], "*)"}], "\[IndentingNewLine]", 
        RowBox[{"gran1", "=", 
         RowBox[{"funcQPRangeEnvelop", "[", 
          RowBox[{"fn", ",", "x00", ",", "x01", ",", "x02"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Print", "[", 
           
           RowBox[{"\"\<[DEBUG] gran1 = \>\"", ",", " ", "gran1", ",", 
            " ", "\"\<; x00 = \>\"", ",", " ", "x00", ",", " ", "\"\<; (\>\"",
             ",", " ", "x01", ",", " ", "\"\<;\>\"", ",", "x02", 
            ",", "\"\<); k = \>\"", ",", " ", "k"}], "]"}], ";"}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"k", ">=", "fl"}], ",", 
          RowBox[{
           RowBox[{"Print", "[", 
            
            RowBox[{"\"\<[WARNING] rough way to get Null Enveloped Ranges \
failed: get \>\"", ",", " ", "i", ",", "\"\< ranges.\>\""}], "]"}], ";", 
           RowBox[{"Goto", "[", "end", "]"}]}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"gran1", "[", 
            RowBox[{"[", "1", "]"}], "]"}], " ", "==", " ", 
           RowBox[{"-", "1"}]}], ",", 
          RowBox[{
           RowBox[{"k", "=", 
            RowBox[{"k", "+", "1"}]}], ";", 
           RowBox[{"Goto", "[", "rechoose", "]"}]}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"dx", "=", 
         RowBox[{"Abs", "[", 
          RowBox[{
           RowBox[{"gran1", "[", 
            RowBox[{"[", "2", "]"}], "]"}], "-", 
           RowBox[{"gran1", "[", 
            RowBox[{"[", "1", "]"}], "]"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"tabQPeriod", ",", "gran1"}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"i", "++"}], ";", 
        RowBox[{"k", "=", "1"}], ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Label", "[", "end", "]"}], ";", "\[IndentingNewLine]", 
     "tabQPeriod"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.971295783523053*^9, 3.9712957842169933`*^9}, {
   3.9712958230089283`*^9, 3.971296131319025*^9}, 3.971296397387331*^9, {
   3.971296441370386*^9, 3.9712970715128*^9}, 3.9713170670698586`*^9, {
   3.9713753291961727`*^9, 3.971375360270359*^9}, {3.9713760199480915`*^9, 
   3.971376047146599*^9}, {3.971376399618307*^9, 3.971376419378351*^9}, {
   3.9713764804418793`*^9, 3.9713765235749073`*^9}, {3.971376594729803*^9, 
   3.971376627450878*^9}, {3.9713767800137653`*^9, 3.9713767971058464`*^9}, {
   3.9713772372784405`*^9, 3.971377240572893*^9}, {3.9713999035813065`*^9, 
   3.971399915934372*^9}, {3.971401280601486*^9, 3.971401287254421*^9}, {
   3.971401486065874*^9, 3.971401488189251*^9}, {3.9714018091212997`*^9, 
   3.9714018164490547`*^9}, {3.9714018472906094`*^9, 3.971401869121872*^9}, {
   3.9714028068436985`*^9, 3.971402827971409*^9}, {3.971403383523079*^9, 
   3.9714033870391235`*^9}, {3.971404129303133*^9, 3.9714041457430935`*^9}, {
   3.971404203075527*^9, 3.9714042902926598`*^9}, {3.9714043628966827`*^9, 
   3.971404367503124*^9}, {3.9714044318170433`*^9, 3.971404460980505*^9}, {
   3.9715468118870945`*^9, 3.971546869295126*^9}, {3.971551555030081*^9, 
   3.971551605811161*^9}, {3.9715516737431374`*^9, 3.9715517415644875`*^9}, {
   3.9715517916721897`*^9, 3.97155180032082*^9}, 3.9715518607393265`*^9, {
   3.971551926944433*^9, 3.971551973642727*^9}, {3.9715528533419914`*^9, 
   3.971552916382681*^9}, {3.9715529568124638`*^9, 3.9715531488884544`*^9}, {
   3.971553210429716*^9, 3.971553227894247*^9}, {3.971553265634945*^9, 
   3.9715532692642307`*^9}, {3.971553424776203*^9, 3.971553430173929*^9}, {
   3.9715543126345844`*^9, 3.9715543177185497`*^9}, {3.971554481709673*^9, 
   3.9715544962654896`*^9}, {3.971554623727009*^9, 3.9715546258515663`*^9}, {
   3.971568845408722*^9, 3.971568911444954*^9}, {3.971571535409544*^9, 
   3.9715715892913246`*^9}, {3.971571656304043*^9, 3.9715717008648453`*^9}, {
   3.9715717821177464`*^9, 3.971571786237137*^9}, {3.9715756645580444`*^9, 
   3.9715756951884365`*^9}, {3.9715767686627254`*^9, 3.97157677160223*^9}, {
   3.9715768189767437`*^9, 3.971576823663908*^9}, 3.9715771264804974`*^9, {
   3.9717539820462875`*^9, 3.971754009614599*^9}, {3.9717553108730907`*^9, 
   3.9717553346543217`*^9}, 3.9717554229375*^9, {3.9717554862978325`*^9, 
   3.971755527346882*^9}, {3.971755812499954*^9, 3.971755867453945*^9}, {
   3.9717558987343044`*^9, 3.9717558993156166`*^9}, {3.971756010112543*^9, 
   3.971756047361902*^9}, {3.971756111284609*^9, 3.971756118810549*^9}, {
   3.9717561723442936`*^9, 3.9717563044927254`*^9}, {3.9717563610650024`*^9, 
   3.9717566129246616`*^9}, {3.971756697936899*^9, 3.9717567380422535`*^9}, {
