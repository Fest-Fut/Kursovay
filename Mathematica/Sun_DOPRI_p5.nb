   3.9213621947513657`*^9}, {3.9213622405575123`*^9, 3.921362272427369*^9}, {
   3.9213623060262723`*^9, 3.9213623230275345`*^9}, {3.9213631195569134`*^9, 
   3.92136312891336*^9}, 3.921366028204785*^9, {3.921371686133207*^9, 
