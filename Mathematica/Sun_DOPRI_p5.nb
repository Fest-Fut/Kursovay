Cell[CellGroupData[{

Cell["Numeric solution", "Subsection",
 CellChangeTimes->{{3.9713781076387596`*^9, 3.9713781366494713`*^9}, {
  3.9713912991075974`*^9, 
  3.971391299660597*^9}},ExpressionUUID->"84432c3b-2cd4-2242-a28f-\
75abaeb6423e"],

Cell["\<\
One of flaws of the [Casas et al] work is that they don\[CloseCurlyQuote]t \
describe how they get the numeric solution from Mathematica. For example, if \
one sees below, it would see that the call to `NDSolve` is quite complex. \
First, we use own coefficients, then we set other parameters to fine tune the \
Mathematica `NDSolve` to obtain numeric result.\
\>", "Text",
 CellChangeTimes->{{3.971391268814516*^9, 
  3.971391453825144*^9}},ExpressionUUID->"41e102c0-c83a-dd45-9a5c-\
340abbeef671"],

Cell[BoxData[
 RowBox[{
  RowBox[{"\[Xi]0", "=", "0.1"}], ";", 
  RowBox[{"\[Xi]1", "=", "1.0"}], ";"}]], "Input",
 CellChangeTimes->{{3.9719876505742264`*^9, 3.9719876560303555`*^9}, 
   3.9724369578168488`*^9},
 CellLabel->"In[19]:=",ExpressionUUID->"efca7aaf-0d68-ba47-8c57-d336338f3509"],

Cell[BoxData[
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{"NDSolve", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"\[ImaginaryI]", "*", 
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"\[Psi]", "[", "\[Xi]", "]"}], ",", "\[Xi]"}], "]"}]}], "==", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"H0", "+", 
           RowBox[{
            RowBox[{"u", "[", "\[Xi]", "]"}], "*", "W"}]}], ")"}], ".", 
         RowBox[{"\[Psi]", "[", "\[Xi]", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{"\[Psi]", "[", "\[Xi]0", "]"}], "==", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"c12", " ", "c13"}], ",", 
          RowBox[{"s12", " ", "c13"}], ",", " ", "s13"}], "}"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Psi]1", ",", "\[Psi]2", ",", "\[Psi]3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Xi]", ",", "\[Xi]0", ",", "\[Xi]1"}], "}"}], ",", " ", 
     RowBox[{"Method", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<ExplicitRungeKutta\>\"", ",", 
        RowBox[{"\"\<Coefficients\>\"", "->", "DOPRICoeffs"}], ",", 
        RowBox[{"\"\<DifferenceOrder\>\"", "->", "5"}], ",", 
        RowBox[{"\"\<StiffnessTest\>\"", "->", "False"}]}], "}"}]}], ",", 
     RowBox[{"StartingStepSize", "->", "0.25"}], ",", 
     RowBox[{"MaxSteps", "->", "Infinity"}], ",", 
     RowBox[{"MaxStepFraction", "->", 
      RowBox[{"1", "/", "12"}]}], ",", 
     RowBox[{"WorkingPrecision", "->", "MachinePrecision"}], ",", 
     RowBox[{"AccuracyGoal", "->", "Infinity"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9207672268920307`*^9, 3.9207672380374613`*^9}, {
   3.920767340427898*^9, 3.920767378900568*^9}, {3.920767412717085*^9, 
   3.9207675081370907`*^9}, {3.9207675923442717`*^9, 3.920767664231278*^9}, {
