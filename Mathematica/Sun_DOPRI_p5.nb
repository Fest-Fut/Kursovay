   3.9715538882215786`*^9}, {3.971554107873165*^9, 3.9715541351594925`*^9}, {
   3.971554385377636*^9, 3.9715544470546856`*^9}, {3.971554647048479*^9, 
   3.9715547005387306`*^9}, {3.9715767410924454`*^9, 
