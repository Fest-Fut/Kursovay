     SuperscriptBox["s13", "2"], "*", 
     SuperscriptBox[
      RowBox[{"Abs", "[", 
       RowBox[{"v", "[", 
        RowBox[{"[", "3", "]"}], "]"}], "]"}], "2"]}]}]}], ";"}]], "Input",
