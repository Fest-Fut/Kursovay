Cell["\<\
It is inconvenient to use full path when exporting (saving) the data. \
Instead, one may use the path relative to the notebook itself, as we do \
below. It is big help that `NotebookDir[]` returns path with path separator \
at the end.

NB: the `<>` is the Mathematica way to join (merge) the string.\
\>", "Text",
 CellChangeTimes->{
  3.971391831419737*^9, {3.971391895422411*^9, 3.9713920104144*^9}, {
   3.9725103608208313`*^9, 
   3.972510362326771*^9}},ExpressionUUID->"0112a14a-f433-2c4e-876f-\
d13b5639f32c"],

Cell[BoxData[
 RowBox[{"(*", " ", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"SetDirectory", "[", "$UserDocumentsDirectory", "]"}], " ",
            "..."}], " ", "\[IndentingNewLine]", 
          RowBox[{"NotebookDirectory", "[", "]"}]}], " ", "..."}], "\[IndentingNewLine]",
         "$HomeDirectory"}], " ", "..."}], "\[IndentingNewLine]", 
      "$UserBaseDirectory"}], " ", "..."}], "\[IndentingNewLine]", 
    "$Username", "\[IndentingNewLine]", 
    RowBox[{"In", "[", ".", "]"}], " ", "$UserBaseDirectory", "\[IndentingNewLine]", 
    RowBox[{"Out", "[", ".", "]"}]}], " ", "->", " ", "dir"}], " ", 
  "*)"}]], "Input",ExpressionUUID->"74f7e729-f3a0-934c-92f5-6b85cb0a1733"],

