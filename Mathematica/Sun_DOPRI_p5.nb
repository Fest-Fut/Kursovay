 RowBox[{
  RowBox[{"a", "=", 
   RowBox[{"4.35196", " ", 
    RowBox[{"10", "^", "6"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "=", "0.030554"}], ";"}]}], "Input",
 CellChangeTimes->{{3.920765773190689*^9, 3.920765892930168*^9}, {
