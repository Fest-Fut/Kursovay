Cell[BoxData[
 RowBox[{
  RowBox[{"funcCountZrsInRanges", "[", 
   RowBox[{"fn_", ",", "tab_", ",", " ", "n_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"i", "=", "1"}], ",", 
      RowBox[{"tabZrs", "=", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{"l", "=", "0"}], ",", 
      RowBox[{"tt", "=", 
       RowBox[{"{", "}"}]}], ",", 
      RowBox[{"nm", "=", "0"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"l", "=", 
      RowBox[{"Length", "[", "tab", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"i", "<=", "l"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"tt", "=", 
         RowBox[{"funcNullRangesStab", "[", 
          RowBox[{"fn", ",", 
           RowBox[{"tab", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
           RowBox[{"tab", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "2"}], "]"}], "]"}], ",", "n"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"nm", "=", 
         RowBox[{"Length", "[", "tt", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"AppendTo", "[", 
         RowBox[{"tabZrs", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"tab", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"tab", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "2"}], "]"}], "]"}], ",", "nm"}], "}"}]}], 
         "]"}], ";", "\[IndentingNewLine]", 
        RowBox[{"i", "++"}]}]}], "\[IndentingNewLine]", "]"}], ";", 
     "\[IndentingNewLine]", "tabZrs"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
