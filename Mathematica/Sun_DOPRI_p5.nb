             RowBox[{"71", "/", "57600"}], ",", "0", ",", 
             RowBox[{
              RowBox[{"-", "71"}], "/", "16695"}], ",", 
             RowBox[{"71", "/", "1920"}], ",", 
             RowBox[{
              RowBox[{"-", "17253"}], "/", "339200"}], ",", 
             RowBox[{"22", "/", "525"}], ",", 
             RowBox[{
              RowBox[{"-", "1"}], "/", "40"}]}], "}"}]}], "}"}], ",", "p"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"sol", "=", 
       RowBox[{"NDSolve", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"\[ImaginaryI]", "*", 
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{"\[Psi]", "[", "\[Xi]", "]"}], ",", "\[Xi]"}], "]"}]}],
             "==", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"H0", "+", 
               RowBox[{
                RowBox[{"u", "[", "\[Xi]", "]"}], "*", "W"}]}], ")"}], ".", 
             RowBox[{"\[Psi]", "[", "\[Xi]", "]"}]}]}], ",", 
           RowBox[{
            RowBox[{"\[Psi]", "[", "\[Xi]0", "]"}], "==", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"c12", " ", "c13"}], ",", 
              RowBox[{"s12", " ", "c13"}], ",", " ", "s13"}], "}"}]}]}], 
          "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Psi]1", ",", "\[Psi]2", ",", "\[Psi]3"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[Xi]", ",", "\[Xi]0", ",", "\[Xi]1"}], "}"}], ",", " ", 
         RowBox[{"Method", "->", 
          RowBox[{"{", 
           RowBox[{"\"\<ExplicitRungeKutta\>\"", ",", 
            RowBox[{"\"\<Coefficients\>\"", "->", "DOPRICoeffs"}], ",", 
            RowBox[{"\"\<DifferenceOrder\>\"", "->", "5"}], ",", 
            RowBox[{"\"\<StiffnessTest\>\"", "->", "False"}]}], "}"}]}], ",", 
         
         RowBox[{"StartingStepSize", "->", "0.25"}], ",", 
         RowBox[{"MaxSteps", "->", "Infinity"}], ",", 
         RowBox[{"MaxStepFraction", "->", 
          RowBox[{"1", "/", "12"}]}], ",", 
         RowBox[{"WorkingPrecision", "->", "MachinePrecision"}], ",", 
         RowBox[{"AccuracyGoal", "->", "Infinity"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"uf", "[", "x_", "]"}], ":=", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Evaluate", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"\[Psi]1", "[", "\[Xi]", "]"}], ",", 
             RowBox[{"\[Psi]2", "[", "\[Xi]", "]"}], ",", 
             RowBox[{"\[Psi]3", "[", "\[Xi]", "]"}]}], "}"}], "/.", "sol"}], 
          "]"}], "/.", 
         RowBox[{"{", 
          RowBox[{"\[Xi]", "->", "x"}], "}"}]}], "/.", 
        RowBox[{
         RowBox[{"{", "\[Xi]_", "}"}], "->", "\[Xi]"}]}]}], ";", 
      "\[IndentingNewLine]", "uf"}]}], "\[IndentingNewLine]", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"TODO", ":", " ", 
       RowBox[{
       "check", " ", "that", " ", "function", " ", "getPsi", " ", "is", " ", 
        RowBox[{"working", ".", " ", "Assumed"}], " ", "interface"}], ":", 
       "\[IndentingNewLine]", "uf"}], "=", 
      RowBox[{"getPsi", "[", "1", "]"}]}], ";", "\[IndentingNewLine]", 
     "Then"}], ",", " ", 
    RowBox[{"the", " ", "below", " ", 
     RowBox[{"(", 
      RowBox[{"with", " ", "uf"}], ")"}], " ", "must", " ", "work", " ", "as",
      " ", "in", " ", "`_p4`", " ", 
     RowBox[{"part", "."}]}]}], "\[IndentingNewLine]", "*)"}]}]}], "Input",
 CellChangeTimes->{{3.972424414043312*^9, 3.9724244156737785`*^9}, {
  3.972424471668455*^9, 3.972424500909481*^9}, {3.972424532794592*^9, 
